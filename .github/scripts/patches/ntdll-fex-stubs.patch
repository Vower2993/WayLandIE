diff --git a/dlls/ntdll/signal_arm64.c b/dlls/ntdll/signal_arm64.c
index 7eddc57..305dc2c 100644
--- a/dlls/ntdll/signal_arm64.c
+++ b/dlls/ntdll/signal_arm64.c
@@ -992,4 +992,61 @@ __ASM_GLOBAL_FUNC( DbgUserBreakPoint, "brk #0xf000; ret"
                     "\n\tnop; nop; nop; nop; nop; nop; nop; nop"
                     "\n\tnop; nop; nop; nop; nop; nop" );
 
+/*
+ * FEX compatibility stubs — provide ARM64EC-only exports for native ARM64 builds.
+ *
+ * Background: FEX's libarm64ecfex.dll imports RtlIsEcCode + ProcessPending-
+ * CrossProcessEmulatorWork from ntdll.dll. These are defined in signal_arm64ec.c
+ * (only compiled when __arm64ec__ is defined). The Wine spec marks them with
+ * -arch=arm64ec, but Wine's import resolver only checks the STANDARD PE export
+ * directory, not the CHPE metadata export table where ARM64EC-specific exports
+ * land for ARM64X hybrid binaries. Result: FEX's imports fail → stub to 0x10000
+ * → SIGSEGV → recursion → stack overflow → FEX never inits.
+ *
+ * Fix: provide implementations for the native ARM64 build, then change the spec
+ * to -arch=win64 so both exports land in the standard PE export directory.
+ *
+ * RtlIsEcCode: checks EcCodeBitMap if available, returns FALSE if bitmap is
+ * NULL (native ARM64 process without CHPE V2). This matches the real
+ * implementation in signal_arm64ec.c except we handle the NULL bitmap case
+ * safely (the real impl assumes bitmap is always set in ARM64EC processes).
+ *
+ * ProcessPendingCrossProcessEmulatorWork: no-op. The real implementation
+ * requires ChpeV2ProcessInfo to be set up (only in ARM64EC processes).
+ * In native ARM64, ChpeV2ProcessInfo is NULL, so there's no work to process.
+ */
+
+#ifndef __arm64ec__
+
+/**********************************************************************
+ *           RtlIsEcCode  (NTDLL.@)
+ *
+ * Check if the given address is ARM64EC (emulated x86_64) code.
+ * Uses EcCodeBitMap if available; returns FALSE if bitmap is NULL
+ * (native ARM64 process without CHPE V2 process info).
+ */
+BOOLEAN WINAPI RtlIsEcCode( ULONG_PTR ptr )
+{
+    const UINT64 *map = (const UINT64 *)NtCurrentTeb()->Peb->EcCodeBitMap;
+    ULONG_PTR page;
+    if (!map) return FALSE;
+    page = ptr / page_size;
+    return (map[page / 64] >> (page & 63)) & 1;
+}
+
+/**********************************************************************
+ *           ProcessPendingCrossProcessEmulatorWork  (NTDLL.@)
+ *
+ * No-op for native ARM64 build. The real implementation (in
+ * signal_arm64ec.c) requires ChpeV2ProcessInfo, which is only set
+ * up in ARM64EC processes. In native ARM64, there is no CHPE V2
+ * cross-process work to process.
+ */
+void WINAPI ProcessPendingCrossProcessEmulatorWork(void)
+{
+    /* no-op — native ARM64 processes don't have CHPE V2 work pending */
+}
+
+#endif  /* !__arm64ec__ */
+
 #endif  /* __aarch64__ */
